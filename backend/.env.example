# ── Neo4j knowledge graph ────────────────────────────────────────────────
# Local: bolt://localhost:7687 | Aura: neo4j+s://<id>.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me
NEO4J_DATABASE=neo4j

# ── Gemini (Google) for explainable AI — OpenAI-compatible endpoint ──────
# Get a key at https://aistudio.google.com/apikey — used by the LangChain
# explanation layer. Leave blank to use the deterministic template fallback.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.5-flash

# ── Africa's Talking (USSD + SMS) ────────────────────────────────────────
# Keep both credential sets; AT_ENVIRONMENT selects the active one:
#   sandbox -> username "sandbox" + AT_SANDBOX_API_KEY (AT sandbox host)
#   live    -> AT_USERNAME + AT_API_KEY + AT_SENDER_ID (production host)
# Leave the active API key blank to run with SMS disabled (USSD still works).
AT_ENVIRONMENT=sandbox
# Live / production:
AT_USERNAME=
AT_API_KEY=
# For TWO-WAY SMS, AT_SENDER_ID must be your shortcode (e.g. 20384).
# Alphanumeric sender IDs are ONE-WAY and cannot receive replies.
AT_SENDER_ID=
# Sandbox (username is always "sandbox"; sandbox API key differs from live):
AT_SANDBOX_API_KEY=
AT_SANDBOX_SENDER_ID=
# Keyword registered on the shortcode for two-way SMS (e.g. Test11). Stripped
# from inbound messages before processing.
AT_SMS_KEYWORD=
AT_USSD_DEFAULT_LANGUAGE=en

# Shared secret protecting POST /api/sms/notify. Leave blank to disable it.
INTERNAL_API_TOKEN=

# ── App ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (the frontend dev/prod URLs).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MODEL_DIR=artifacts
