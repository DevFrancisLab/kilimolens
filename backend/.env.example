# ── Neo4j knowledge graph ────────────────────────────────────────────────
# Local: bolt://localhost:7687 | Aura: neo4j+s://<id>.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me
NEO4J_DATABASE=neo4j

# ── Featherless AI (OpenAI-compatible inference for explainable AI) ───────
# Get a key at https://featherless.ai — used by the LangChain explanation layer.
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── App ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (the frontend dev/prod URLs).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MODEL_DIR=artifacts
