# ── Neo4j knowledge graph ────────────────────────────────────────────────
# Local: bolt://localhost:7687 | Aura: neo4j+s://<id>.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me
NEO4J_DATABASE=neo4j

# ── Gemini (Google) for explainable AI — OpenAI-compatible endpoint ──────
# Get a key at https://aistudio.google.com/apikey — used by the LangChain
# explanation layer. Leave blank to use the deterministic template fallback.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.5-flash

# ── Africa's Talking (USSD + SMS) ────────────────────────────────────────
# Username "sandbox" targets the AT sandbox; use your live username in prod.
# Leave AT_API_KEY blank to run with SMS disabled (USSD still works; outbound
# SMS is skipped and logged). AT_SENDER_ID is your registered shortcode or
# alphanumeric sender id (optional).
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=
AT_USSD_DEFAULT_LANGUAGE=en

# Shared secret protecting POST /api/sms/notify. Leave blank to disable it.
INTERNAL_API_TOKEN=

# ── App ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (the frontend dev/prod URLs).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MODEL_DIR=artifacts
