# ── Masumi Payment Service (per the masumi-network quickstart) ───────────────
# Leave PAYMENT_API_KEY blank to run the agents with a LOCAL MOCK payment
# provider (full MIP-003 flow, no blockchain) — ideal for development/demo.
PAYMENT_SERVICE_URL=http://localhost:3001/api/v1
PAYMENT_API_KEY=
NETWORK=Preprod

# Each agent registers separately on Masumi and has its own identity.
FARMER_TRUST_AGENT_IDENTIFIER=
FARMER_TRUST_SELLER_VKEY=
FARMER_TRUST_PRICE_LOVELACE=2000000

COOP_INTEL_AGENT_IDENTIFIER=
COOP_INTEL_SELLER_VKEY=
COOP_INTEL_PRICE_LOVELACE=2500000

# ── Shared data substrate (read-only) — the KilimoLens Neo4j knowledge graph ──
# These agents are INDEPENDENT services; Neo4j is just their data source.
NEO4J_URI=neo4j+s://<id>.databases.neo4j.io
NEO4J_USER=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ── Gemini (explainability — every score is explained, never just a number) ──
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.5-flash
